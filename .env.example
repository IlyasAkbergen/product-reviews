# Copy to .env in the repository root (docker compose picks it up from there).
# The Symfony backend reads variables from backend/.env — for Docker, values are set by docker-compose.yml.

# Application environment (dev|prod)
APP_ENV=dev

# MySQL (mysql service in docker-compose)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=product_review
MYSQL_USER=app
MYSQL_PASSWORD=apppassword

# RabbitMQ (Messenger queue)
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Passphrase for Lexik JWT keys (must match backend JWT_PASSPHRASE when running locally outside Docker)
JWT_PASSPHRASE=your_strong_passphrase_here

# API URL for Vite (browser connects to nginx on localhost)
VITE_API_URL=http://localhost:8080

# Redis (rating aggregate cache; in Docker — redis://redis:6379 from compose)
REDIS_URL=redis://127.0.0.1:6379
